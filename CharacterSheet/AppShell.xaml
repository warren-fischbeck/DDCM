<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="CharacterSheet.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:CharacterSheet"
    Title="Character Sheet">

    <ShellContent
        Title="Character Sheet"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    <ShellContent
        Title="Class Builder"
        ContentTemplate="{DataTemplate local:ClassBuilder}"
        Route="ClassBuilder" />
    <ShellContent
        Title="Character Builder"
        ContentTemplate="{DataTemplate local:CharacterBuilder}"
        Route="CharacterBuilder" />
    <ShellContent
        Title="Character List"
        ContentTemplate="{DataTemplate local:CharacterList}"
        Route="CharacterList" />

</Shell>
